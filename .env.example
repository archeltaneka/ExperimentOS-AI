DATABASE_URL=postgresql+psycopg://experimentos:experimentos@localhost:5433/experimentos
APP_ENV=local
API_HOST=127.0.0.1
API_PORT=8000
EMBEDDING_PROVIDER=auto
LLM_PROVIDER=auto
GEMINI_MODEL=gemini-3.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_API_KEY=

# LangSmith observability is optional and disabled by default.
# Enabling it sends selected redacted metadata to an external service.
EXPERIMENTOS_LANGSMITH_ENABLED=false
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=
LANGSMITH_PROJECT=experimentos-local
EXPERIMENTOS_LANGSMITH_ENVIRONMENT=development
EXPERIMENTOS_LANGSMITH_SAMPLING_RATE=0.0
EXPERIMENTOS_LANGSMITH_TRACE_INPUTS=false
EXPERIMENTOS_LANGSMITH_TRACE_OUTPUTS=false
EXPERIMENTOS_LANGSMITH_REDACT_SENSITIVE_DATA=true
EXPERIMENTOS_LANGSMITH_TAGS=local
EXPERIMENTOS_LANGSMITH_STRICT=false
EXPERIMENTOS_LANGSMITH_ALWAYS_TRACE_ERRORS=true

# Phoenix observability is optional and disabled by default.
# It exports ExperimentOS-owned manual spans through the Phoenix adapter only when enabled.
EXPERIMENTOS_PHOENIX_ENABLED=false
EXPERIMENTOS_PHOENIX_ENDPOINT=http://127.0.0.1:6006/v1/traces
EXPERIMENTOS_PHOENIX_API_KEY=
EXPERIMENTOS_PHOENIX_PROJECT=experimentos-local
EXPERIMENTOS_PHOENIX_ENVIRONMENT=development
EXPERIMENTOS_PHOENIX_TRANSPORT=http/protobuf
EXPERIMENTOS_PHOENIX_SAMPLING_RATE=1.0
EXPERIMENTOS_PHOENIX_TRACE_INPUTS=false
EXPERIMENTOS_PHOENIX_TRACE_OUTPUTS=false
EXPERIMENTOS_PHOENIX_TRACE_RETRIEVAL_CONTENT=false
EXPERIMENTOS_PHOENIX_TRACE_PROMPT_CONTENT=false
EXPERIMENTOS_PHOENIX_REDACT_SENSITIVE_DATA=true
EXPERIMENTOS_PHOENIX_HEADERS=
EXPERIMENTOS_PHOENIX_TAGS=local
EXPERIMENTOS_PHOENIX_STRICT=false
EXPERIMENTOS_PHOENIX_ALWAYS_TRACE_ERRORS=true
EXPERIMENTOS_PHOENIX_MAX_STRING_LENGTH=512
EXPERIMENTOS_PHOENIX_MAX_COLLECTION_LENGTH=25
EXPERIMENTOS_PHOENIX_MAX_METADATA_DEPTH=5
EXPERIMENTOS_PHOENIX_MAX_RETRIEVAL_RECORDS=10
