DATABASE_URL=postgresql+psycopg://experimentos:experimentos@localhost:5433/experimentos
APP_ENV=local
API_HOST=127.0.0.1
API_PORT=8000
# Offline-safe defaults. Select `auto` or a live provider name explicitly when intended.
EMBEDDING_PROVIDER=fake
LLM_PROVIDER=mock
GEMINI_MODEL=gemini-3.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_API_KEY=
PROMPT_EXPERIMENTS_ENABLED=false
ACTIVE_PROMPT_EXPERIMENT_ID=
PROMPT_EXPERIMENT_ASSIGNMENT_SALT=

# LangSmith observability is optional and disabled by default.
# Enabling it sends selected redacted metadata to an external service.
EXPERIMENTOS_LANGSMITH_ENABLED=false
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=
LANGSMITH_PROJECT=experimentos-local
EXPERIMENTOS_LANGSMITH_ENVIRONMENT=development
EXPERIMENTOS_LANGSMITH_SAMPLING_RATE=0.0
EXPERIMENTOS_LANGSMITH_TRACE_INPUTS=false
EXPERIMENTOS_LANGSMITH_TRACE_OUTPUTS=false
EXPERIMENTOS_LANGSMITH_REDACT_SENSITIVE_DATA=true
EXPERIMENTOS_LANGSMITH_TAGS=local
EXPERIMENTOS_LANGSMITH_STRICT=false
EXPERIMENTOS_LANGSMITH_ALWAYS_TRACE_ERRORS=true

# Phoenix observability is optional and disabled by default.
# It exports ExperimentOS-owned manual spans through the Phoenix adapter only when enabled.
EXPERIMENTOS_PHOENIX_ENABLED=false
EXPERIMENTOS_PHOENIX_ENDPOINT=http://127.0.0.1:6006/v1/traces
EXPERIMENTOS_PHOENIX_API_KEY=
EXPERIMENTOS_PHOENIX_PROJECT=experimentos-local
EXPERIMENTOS_PHOENIX_ENVIRONMENT=development
EXPERIMENTOS_PHOENIX_TRANSPORT=http/protobuf
EXPERIMENTOS_PHOENIX_SAMPLING_RATE=1.0
EXPERIMENTOS_PHOENIX_TRACE_INPUTS=false
EXPERIMENTOS_PHOENIX_TRACE_OUTPUTS=false
EXPERIMENTOS_PHOENIX_TRACE_RETRIEVAL_CONTENT=false
EXPERIMENTOS_PHOENIX_TRACE_PROMPT_CONTENT=false
EXPERIMENTOS_PHOENIX_REDACT_SENSITIVE_DATA=true
EXPERIMENTOS_PHOENIX_HEADERS=
EXPERIMENTOS_PHOENIX_TAGS=local
EXPERIMENTOS_PHOENIX_STRICT=false
EXPERIMENTOS_PHOENIX_ALWAYS_TRACE_ERRORS=true
EXPERIMENTOS_PHOENIX_MAX_STRING_LENGTH=512
EXPERIMENTOS_PHOENIX_MAX_COLLECTION_LENGTH=25
EXPERIMENTOS_PHOENIX_MAX_METADATA_DEPTH=5
EXPERIMENTOS_PHOENIX_MAX_RETRIEVAL_RECORDS=10

# OpenTelemetry is optional and disabled by default.
# It exports the same ExperimentOS-owned manual spans and metrics through a vendor-neutral SDK.
EXPERIMENTOS_OTEL_ENABLED=false
EXPERIMENTOS_OTEL_SERVICE_NAME=experimentos-ai
EXPERIMENTOS_OTEL_SERVICE_NAMESPACE=experimentos
EXPERIMENTOS_OTEL_SERVICE_VERSION=0.1.0
EXPERIMENTOS_OTEL_ENVIRONMENT=development
EXPERIMENTOS_OTEL_EXPORTER_TYPE=none
EXPERIMENTOS_OTEL_EXPORTER_ENDPOINT=http://127.0.0.1:4318/v1/traces
EXPERIMENTOS_OTEL_PROTOCOL=http/protobuf
EXPERIMENTOS_OTEL_EXPORTER_HEADERS=
EXPERIMENTOS_OTEL_TRACE_ENABLED=true
EXPERIMENTOS_OTEL_METRICS_ENABLED=true
EXPERIMENTOS_OTEL_SAMPLING_RATE=1.0
EXPERIMENTOS_OTEL_BATCH_EXPORT=true
EXPERIMENTOS_OTEL_EXPORT_TIMEOUT_MS=30000
EXPERIMENTOS_OTEL_METRIC_EXPORT_INTERVAL_MS=60000
EXPERIMENTOS_OTEL_TRACE_INPUTS=false
EXPERIMENTOS_OTEL_TRACE_OUTPUTS=false
EXPERIMENTOS_OTEL_REDACT_SENSITIVE_DATA=true
EXPERIMENTOS_OTEL_RESOURCE_ATTRIBUTES=
EXPERIMENTOS_OTEL_TAGS=local
EXPERIMENTOS_OTEL_PROPAGATION_ENABLED=true
EXPERIMENTOS_OTEL_INSTRUMENT_FASTAPI=true
EXPERIMENTOS_OTEL_EXCLUDED_URLS=^/health$
EXPERIMENTOS_OTEL_STRICT=false
EXPERIMENTOS_OTEL_ALWAYS_TRACE_ERRORS=true
EXPERIMENTOS_OTEL_MAX_STRING_LENGTH=512
EXPERIMENTOS_OTEL_MAX_COLLECTION_LENGTH=25
EXPERIMENTOS_OTEL_MAX_METADATA_DEPTH=5
EXPERIMENTOS_OTEL_MAX_RETRIEVAL_RECORDS=10
